# Copy to .env and fill in real values. Do not commit .env.

# Required. Postgres connection string. Must have pgvector extension enabled.
DATABASE_URL=postgresql://user:password@host:5432/eu_parliq

# Required. Used for embeddings (text-embedding-3-small).
OPENAI_API_KEY=sk-...

# Required. Used for Claude answers (Haiku quick mode, Sonnet deep mode).
ANTHROPIC_API_KEY=sk-ant-...

# Required in production, optional in dev (defaults to "dev-secret-local-only").
JWT_SECRET=change-me-to-a-long-random-string

# Optional. "development" or "production". Defaults to "development".
NODE_ENV=development

# Optional. HTTP port. Defaults to 3000.
PORT=3000
